.env
.env.*
!.env.example
.DS_Store
__pycache__
.idea
KMS
.venv
.vscode
*.egg-info
.pytest_cache
.ruff_cache

# Ingestion corpus: source PDFs and raw Unsiloed parse cache (often large/proprietary).
# The distilled chunks live in knowledge.json, which IS tracked.
corpus/pdfs/*
corpus/parsed/*
!corpus/pdfs/.gitkeep
!corpus/parsed/.gitkeep

# Claude Code
.claude/settings.local.json
.claude/worktrees/

# OpenAI Codex
.codex/config.local.toml

# Gemini CLI
.gemini/history/
.gemini/tmp/
.gemini/google_accounts.json
.gemini/installation_id
.gemini/oauth_creds.json

# Cursor
.cursor/chat/
.cursor/rules/*.local.mdc

# GitHub CLI
.github/personal-instructions.md
corpus/raw/*
!corpus/raw/.gitkeep
