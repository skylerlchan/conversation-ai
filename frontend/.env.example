# Enviroment variables needed to connect to the LiveKit server.
LIVEKIT_API_KEY=<your_api_key>
LIVEKIT_API_SECRET=<your_api_secret>
LIVEKIT_URL=wss://<project-subdomain>.livekit.cloud

# Agent dispatch (https://docs.livekit.io/agents/server/agent-dispatch)
# Leave AGENT_NAME blank to enable automatic dispatch
# Provide an agent name to enable explicit dispatch.
# Moss dispatches explicitly to the Python agent registered as `agent-py`.
AGENT_NAME=agent-py

# Internally used environment variables
NEXT_PUBLIC_APP_CONFIG_ENDPOINT=
SANDBOX_ID=

# "Ask about this call" chat under the live call (OpenAI-compatible providers).
# Set the sponsor key for whichever model(s) you want enabled in the picker.
MINIMAX_API_KEY=<your_minimax_key>
QWEN_API_KEY=<your_qwen_dashscope_key>
# Optional overrides (defaults are the latest: MiniMax-M3 and qwen3-max):
# MINIMAX_MODEL=MiniMax-M3
# QWEN_MODEL=qwen3-max

# Moss live querying for the chat (same project credentials as agent-py/.env.local).
# Without these the chat still works, grounded only in the surfaced call context.
MOSS_PROJECT_ID=<your_moss_project_id>
MOSS_PROJECT_KEY=<your_moss_project_key>
MOSS_INDEX_NAME=knowledge
# MOSS_TOP_K=5
# MINIMAX_BASE_URL=https://api.minimax.io/v1
# QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
